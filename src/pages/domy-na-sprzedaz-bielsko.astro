---
import Layout from "../layouts/Layout.astro";
import Header from "../components/layout/Header.astro";
import Footer from "../components/layout/Footer.astro";
import Container from "../components/ui/Container.astro";
import Button from "../components/ui/Button.astro";
import { Image } from "astro:assets";
import houseImage from "../assets/images/nowoczesny-dom-na-sprzedaz-bielsko.jpg";

const districts = [
  {
    name: "Pisarzowice",
    offers: [
      {
        title: "Dom Wolnostojący Pisarzowice (Etap II)",
        price: "895 000 zł",
        size: "135 m²",
        plot: "700 m²", // Zakładam przykładową, ew. do usunięcia w kodzie jeśli niepotrzebna, ale zostawię dla spójności układu
        status: "Stan deweloperski",
        features: ["Garaż", "Ogrzewanie gazowe", "2 łazienki", "3 sypialnie"],
        image: houseImage,
        description:
          "Rozpoczynamy drugi etap budowy domów jednorodzinnych, położonych w spokojnej i zielonej okolicy w Pisarzowicach. To kontynuacja zrealizowanego już etapu pierwszego, w ramach którego wybudowano i sprzedano 6 domów.\n\nDomy zostaną wybudowany z wysokiej jakości materiałów. Posiadają przestronny salon, dwie łazienki, garaż oraz trzy sypialnie.Idealne dla rodziny ceniącej komfort, bliskość natury. Położone są w dogodnej lokalizacji, niedaleko znajduje się szkoła podstawowa, przystanek autobusowy, sklepy spożywcze i punkty usługowe.\n\nZamieszczone zdjęcia przedstawiają sprzedany budynek w pierwszym etapie. Zainteresowanych zapraszam do kontaktu i umówienia się na prezentację.",
      },
    ],
  },
];
---

<Layout
  title="Nowe domy na sprzedaż Bielsko-Biała | Inwestycje | INVESTDOM"
  description="Poznaj nasze aktualne inwestycje deweloperskie w Bielsku-Białej i okolicach. Gotowe domy na sprzedaż w stanie deweloperskim m.in w atrakcyjnych dzielnicach, takich jak Pisarzowice."
>
  <Header />
  <main class="pt-32 pb-16 bg-stone-50 min-h-screen">
    <Container>
      <div class="text-center max-w-3xl mx-auto mb-16">
        <span
          class="inline-block px-4 py-2 bg-navy-900/10 text-navy-900 text-sm font-medium rounded-full mb-4"
          >Oferta deweloperska</span
        >
        <h1
          class="font-heading font-bold text-4xl md:text-5xl text-navy-900 mb-6"
        >
          Nowe domy na sprzedaż w Bielsku-Białej
        </h1>
        <p class="text-lg text-slate-600">
          Zrealizowane w wysokim standardzie, nowoczesne domy jednorodzinne
          czekają na nowych właścicieli. Wybierz dzielnicę i znajdź dom dla
          swojej rodziny.
        </p>
      </div>

      <div class="space-y-16">
        {
          districts.map((district) => (
            <div>
              <h2 class="text-3xl font-bold text-navy-900 mb-8 border-b border-stone-200 pb-4">
                Inwestycje: {district.name}
              </h2>

              <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
                {district.offers.map((offer) => (
                  <div class="bg-white rounded-3xl overflow-hidden shadow-lg border border-stone-100 flex flex-col">
                    <div class="relative h-64">
                      <Image
                        src={offer.image}
                        alt={offer.title}
                        class="absolute inset-0 w-full h-full object-cover"
                        width={800}
                        height={600}
                        quality={80}
                      />
                      <div class="absolute top-4 left-4">
                        <span class="px-3 py-1 bg-green-500 text-white text-xs font-bold rounded-full shadow-lg uppercase tracking-wide">
                          {offer.status}
                        </span>
                      </div>
                    </div>

                    <div class="p-8 flex flex-col flex-grow">
                      <h3 class="font-bold text-2xl text-navy-900 mb-4">
                        {offer.title}
                      </h3>

                      <div class="grid grid-cols-2 gap-4 mb-6 text-sm">
                        <div class="bg-stone-50 p-3 rounded-xl">
                          <span class="block text-slate-500 mb-1">
                            Powierzchnia
                          </span>
                          <span class="font-bold text-navy-900 text-lg">
                            {offer.size}
                          </span>
                        </div>
                        <div class="bg-stone-50 p-3 rounded-xl col-span-2">
                          <span class="block text-slate-500 mb-1">Działka</span>
                          <span class="font-bold text-navy-900 text-lg">
                            {offer.plot}
                          </span>
                        </div>
                      </div>

                      <div class="mb-6 mt-2">
                        {offer.description && (
                          <div class="text-slate-600 text-sm leading-relaxed space-y-3">
                            {offer.description
                              .split("\n\n")
                              .map((paragraph) => (
                                <p>{paragraph}</p>
                              ))}
                          </div>
                        )}
                      </div>

                      <div class="flex flex-wrap gap-2 mb-8">
                        {offer.features.map((feat) => (
                          <span class="px-3 py-1 bg-navy-50 text-navy-900 text-sm rounded-full border border-navy-100">
                            {feat}
                          </span>
                        ))}
                      </div>

                      <div class="mt-auto flex items-center justify-between pt-6 border-t border-stone-100">
                        <div>
                          <span class="block text-slate-500 text-sm">
                            Cena:
                          </span>
                          <span class="font-bold text-2xl text-navy-900">
                            {offer.price}
                          </span>
                        </div>
                        <Button href="/#kontakt" variant="primary">
                          Zapytaj o detale
                        </Button>
                      </div>
                    </div>
                  </div>
                ))}
              </div>
              {district.offers.length === 0 && (
                <p class="text-slate-500 italic">
                  Brak wolnych domów w tej lokalizacji. Zapytaj o nadchodzące
                  inwestycje.
                </p>
              )}
            </div>
          ))
        }
      </div>
    </Container>
  </main>
  <Footer />
</Layout>
