---
import Layout from "../layouts/Layout.astro";
import Header from "../components/layout/Header.astro";
import Footer from "../components/layout/Footer.astro";
import Container from "../components/ui/Container.astro";
import { Image } from "astro:assets";
import projectImage from "../assets/images/nowoczesny-dom-na-sprzedaz-bielsko.jpg";

const projects = [
  {
    id: 1,
    title: "Dom Wolnostojący Pisarzowice (Etap II)",
    size: "135 m²",
    rooms: 4,
    bathrooms: 2,
    image: projectImage,
  },
];
---

<Layout
  title="Projekty Domów Bielsko-Biała | Autorskie Projekty | INVESTDOM"
  description="Zobacz naszą bazę sprawdzonych projektów domów jednorodzinnych. Domy parterowe, z poddaszem użytkowym i piętrowe, gotowe do realizacji w Bielsku-Białej i okolicach."
>
  <Header />
  <main class="pt-32 pb-16 bg-white min-h-screen">
    <Container>
      <div class="text-center max-w-3xl mx-auto mb-16">
        <span
          class="inline-block px-4 py-2 bg-navy-900/10 text-navy-900 text-sm font-medium rounded-full mb-4"
          >Nasze projekty</span
        >
        <h1
          class="font-heading font-bold text-4xl md:text-5xl text-navy-900 mb-6"
        >
          Autorskie Projekty Domów
        </h1>
        <p class="text-lg text-slate-600">
          Wybraliśmy i zoptymalizowaliśmy projekty domów jednorodzinnych, które
          idealnie wpisują się w potrzeby nowoczesnej rodziny oraz uwarunkowania
          terenowe Śląska i Podbeskidzia.
        </p>
      </div>

      <div
        class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6"
      >
        {
          projects.map((project) => (
            <div class="bg-stone-50 rounded-2xl overflow-hidden border border-stone-100 hover:shadow-xl transition-all duration-300 group cursor-pointer">
              <div class="relative h-48 overflow-hidden bg-white flex items-center justify-center p-4">
                <Image
                  src={project.image}
                  alt={project.title}
                  class="w-full h-full object-cover rounded-xl group-hover:scale-105 transition-transform duration-500"
                  width={400}
                  height={300}
                />
              </div>

              <div class="p-6">
                <h3 class="font-bold text-lg text-navy-900 mb-4 truncate">
                  {project.title}
                </h3>

                <div class="space-y-2 mb-6">
                  <div class="flex justify-between text-sm border-b border-stone-200 pb-2">
                    <span class="text-slate-500">Pow. użytkowa:</span>
                    <span class="font-medium text-navy-900">
                      {project.size}
                    </span>
                  </div>
                  <div class="flex justify-between text-sm border-b border-stone-200 pb-2">
                    <span class="text-slate-500">Ilość pokoi (P/S):</span>
                    <span class="font-medium text-navy-900">
                      {project.rooms}
                    </span>
                  </div>
                  <div class="flex justify-between text-sm border-b border-stone-200 pb-2">
                    <span class="text-slate-500">Łazienki:</span>
                    <span class="font-medium text-navy-900">
                      {project.bathrooms}
                    </span>
                  </div>
                </div>

                <a
                  href="/#kontakt"
                  class="block w-full text-center py-2.5 bg-white border border-navy-900 text-navy-900 rounded-lg hover:bg-navy-900 hover:text-white transition-colors text-sm font-medium"
                >
                  Wycena budowy tego projektu
                </a>
              </div>
            </div>
          ))
        }
      </div>
    </Container>
  </main>
  <Footer />
</Layout>
